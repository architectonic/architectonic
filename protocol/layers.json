{
  "schema_version": 2,
  "protocol_version": "0.2.0",
  "layers": {
    "constitution": {
      "packageName": "architectonic-constitution",
      "entry": "constitution.md",
      "purpose": "organizational invariants, composition, and amendment boundaries",
      "localEntry": "organization/constitution.md",
      "standalone": true
    },
    "doctrine": {
      "packageName": "architectonic-doctrine",
      "entry": "doctrine.md",
      "purpose": "purpose, conduct, authority, evidence, incentives, and decision rules",
      "localEntry": "organization/doctrine.md",
      "standalone": true
    },
    "identity": {
      "packageName": "architectonic-identity",
      "entry": "START_HERE.md",
      "purpose": "actors, roles, authority, delegation, incentives, and privacy",
      "localEntry": "organization/actors.md",
      "standalone": true
    },
    "project": {
      "packageName": "architectonic-project",
      "entry": "START_HERE.md",
      "purpose": "bounded operating context, sources, decisions, risks, and continuity",
      "localEntry": "organization/projects/index.md",
      "standalone": true
    },
    "skills": {
      "packageName": "architectonic-skills",
      "entry": "README.md",
      "purpose": "reusable procedures with verification, provenance, and failure handling",
      "localEntry": "organization/skills/index.md",
      "standalone": true
    },
    "knowledge": {
      "packageName": "architectonic-knowledge",
      "entry": "knowledge.md",
      "purpose": "claims, sources, evidence, uncertainty, contradictions, and known unknowns",
      "localEntry": "organization/knowledge/index.md",
      "standalone": true
    },
    "models": {
      "packageName": "architectonic-models",
      "entry": "README.md",
      "purpose": "dated model and retrieval evidence, capability requirements, and routing policy",
      "localEntry": "organization/models.md",
      "standalone": true
    },
    "agents": {
      "packageName": "architectonic-agents",
      "entry": "README.md",
      "purpose": "software-actor composition, permissions, prompts, evaluations, and attachments",
      "localEntry": "organization/agents/index.md",
      "standalone": true,
      "companions": ["identity", "skills", "knowledge", "models", "meta"]
    },
    "rail": {
      "packageName": "architectonic-rail",
      "entry": "rail.md",
      "purpose": "one canonical work ledger, dependency-aware selection, review, evidence, and human gates",
      "localEntry": "organization/rail.md",
      "ledgerPath": "operations/ledger.json",
      "ledgerTemplate": "templates/ledger.json",
      "validator": "bin/architectonic-rail.js",
      "standalone": true,
      "companions": ["project", "identity", "skills", "agents"]
    },
    "living-knowledge": {
      "packageName": "architectonic-living-knowledge",
      "entry": "living-knowledge.md",
      "purpose": "governed maintenance for frequently changing knowledge corpora",
      "localEntry": "organization/living-knowledge.md",
      "standalone": false,
      "operationalRequires": ["knowledge", "rail"],
      "companions": ["skills", "meta"]
    },
    "meta": {
      "packageName": "architectonic-meta",
      "entry": "meta.md",
      "purpose": "audit, drift review, failure learning, revision, and retirement",
      "localEntry": "organization/meta.md",
      "standalone": true
    }
  }
}
